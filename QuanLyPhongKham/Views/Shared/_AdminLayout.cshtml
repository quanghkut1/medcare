@{
    var active = (ViewData["Active"] as string) ?? "";
    string NavCls(string key) => active == key ? "adm-nav-item active" : "adm-nav-item";
    var uname = User.Identity?.Name;
    var initial = string.IsNullOrWhiteSpace(uname) ? "A" : uname.Trim()[..1].ToUpper();
}
<!doctype html>
<html lang="vi">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · MedCare Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" media="print" onload="this.media='all'"
        href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap&subset=latin,vietnamese" />
    <link rel="stylesheet" href="~/css/styles.css?v=25" />
    <script defer src="https://cdn.jsdelivr.net/npm/lucide@0.460.0/dist/umd/lucide.min.js"></script>
    <style>
        body { margin:0; background:#eef3fa; font-family:"Be Vietnam Pro","Segoe UI",sans-serif; color:#0f172a; }
        a { text-decoration:none; }
        .adm-shell { display:flex; min-height:100vh; }

        /* ── Sidebar ── */
        .adm-sidebar { width:250px; flex-shrink:0; background:linear-gradient(185deg,#0d1b40,#103a86);
            color:#fff; padding:22px 14px; position:sticky; top:0; height:100vh; display:flex; flex-direction:column; }
        .adm-logo { display:flex; align-items:center; gap:10px; padding:6px 10px 0; margin-bottom:28px; }
        .adm-logo .lm { width:36px; height:36px; border-radius:10px; background:linear-gradient(135deg,#1057a4,#00b896);
            display:flex; align-items:center; justify-content:center; }
        .adm-logo .lm svg { width:20px; height:20px; fill:#fff; }
        .adm-logo span { font-family:"Fraunces",serif; font-size:22px; font-weight:700; }
        .adm-section { font-size:10.5px; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,.4);
            padding:0 12px; margin:14px 0 8px; }
        .adm-nav-item { display:flex; align-items:center; gap:12px; padding:11px 14px; border-radius:12px;
            color:rgba(255,255,255,.72); font-size:14px; font-weight:500; margin-bottom:4px; transition:.2s; }
        .adm-nav-item:hover { background:rgba(255,255,255,.09); color:#fff; }
        .adm-nav-item.active { background:rgba(255,255,255,.18); color:#fff; font-weight:700; box-shadow:inset 3px 0 0 #00e0b0; }
        .adm-nav-item i { width:18px; height:18px; stroke-width:2; }
        .adm-spacer { flex:1; }

        /* ── Main ── */
        .adm-main { flex:1; min-width:0; display:flex; flex-direction:column; }
        .adm-topbar { height:68px; background:#fff; border-bottom:1px solid #e6edf7; display:flex;
            align-items:center; justify-content:space-between; padding:0 30px; position:sticky; top:0; z-index:5; }
        .adm-topbar h1 { font-family:"Fraunces",serif; font-size:22px; font-weight:700; margin:0; color:#0f172a; }
        .adm-user { display:flex; align-items:center; gap:10px; font-size:13px; color:#475569; }
        .adm-user .av { width:36px; height:36px; border-radius:50%; background:linear-gradient(135deg,#7c3aed,#6f42c1);
            color:#fff; display:flex; align-items:center; justify-content:center; font-weight:700; }
        .adm-content { padding:28px 30px 50px; }

        /* ── Cards / tables ── */
        .adm-card { background:#fff; border:1px solid #e8eef7; border-radius:18px;
            box-shadow:0 2px 10px rgba(16,24,40,.04); }
        .adm-table { width:100%; border-collapse:collapse; }
        .adm-table thead th { padding:13px 18px; text-align:left; font-size:11px; color:#94a3b8;
            font-weight:700; letter-spacing:.5px; text-transform:uppercase; background:#f8fbff; }
        .adm-table tbody td { padding:14px 18px; font-size:13.5px; border-top:1px solid #f1f5f9; }
        .adm-table tbody tr:hover { background:#f8fbff; }
        .badge { padding:4px 12px; border-radius:20px; font-size:11.5px; font-weight:700; display:inline-block; }
        .btn-pri { background:linear-gradient(135deg,#1057a4,#0a3f7f); color:#fff; border:none; border-radius:11px;
            padding:11px 18px; font-weight:700; font-size:14px; cursor:pointer; font-family:inherit; }
        @@media (max-width:820px){
            .adm-sidebar { width:68px; padding:18px 8px; }
            .adm-logo span, .adm-section, .adm-nav-item span { display:none; }
            .adm-nav-item { justify-content:center; }
        }
    </style>
</head>
<body>
    <div class="adm-shell">
        <aside class="adm-sidebar">
            <a class="adm-logo" href="/">
                <span class="lm"><svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg></span>
                <span>MedCare</span>
            </a>
            <div class="adm-section">Quản trị</div>
            <a class="@NavCls("dashboard")" href="/Home/AdminDashboard"><i data-lucide="layout-dashboard"></i><span>Tổng quan</span></a>
            <a class="@NavCls("accounts")" href="/Home/QuanLyTaiKhoan"><i data-lucide="users"></i><span>Quản lý tài khoản</span></a>
            <div class="adm-spacer"></div>
            <div class="adm-section">Khác</div>
            <a class="adm-nav-item" href="/"><i data-lucide="home"></i><span>Về trang chủ</span></a>
            <a class="adm-nav-item" href="/Auth/Logout"><i data-lucide="log-out"></i><span>Đăng xuất</span></a>
        </aside>

        <div class="adm-main">
            <header class="adm-topbar">
                <h1>@ViewData["Title"]</h1>
                <div class="adm-user">
                    <span>@(string.IsNullOrWhiteSpace(uname) ? "Admin" : uname)</span>
                    <div class="av">@initial</div>
                </div>
            </header>
            <main class="adm-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script>
        function initI(){ if (window.lucide && lucide.createIcons) lucide.createIcons(); }
        window.addEventListener("DOMContentLoaded", initI);
        window.addEventListener("load", initI);
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
